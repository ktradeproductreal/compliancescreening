    "express-rate-limit": "^7.4.0",
    "fast-xml-parser": "^4.5.6",
    "fuse.js": "^7.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.0",
    "pdfkit": "^0.15.0",
    "playwright": "^1.61.0",
    "unidecode": "^0.1.8",
    "xlsx": "^0.18.5"
