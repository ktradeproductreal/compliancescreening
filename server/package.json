{
  "name": "compliance-portal-server",
  "version": "1.0.0",
  "private": true,
  "description": "Compliance Screening Portal — Express REST API",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "start:prod": "node src/index.js",
    "db:migrate": "node src/db/migrate.js",
