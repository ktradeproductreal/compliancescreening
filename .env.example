# ─── Root env: shared by docker-compose AND the backend ──────────────────────
# Copy to `.env` and adjust. docker-compose reads DB_* to provision MySQL;
# the backend reads the same vars so local dev and the container stay in sync.

# Database (mysql2 connection pool — Cloud SQL friendly, see deployment memory)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=compliance
DB_USER=compliance
DB_PASSWORD=compliance
# Only used by docker-compose to set the container's root password:
DB_ROOT_PASSWORD=rootpass

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Shared secret for the external /api/v2/screen PDF API (leave blank to disable it).
API_KEY=

# Server
PORT=4000
# Comma-separated allowed origins for CORS (Vite dev server by default):
CORS_ORIGIN=http://localhost:5173

# Seed user (used by `npm run db:seed` to create the first Compliance Officer)
SEED_USER_EMAIL=officer@example.com
SEED_USER_PASSWORD=ChangeMe123!
SEED_USER_NAME=Compliance Officer

# Fuzzy match minimum similarity (1 - Fuse distance; higher = stricter).
# UNSC tuned to 0.65 to drop floor-noise seen on real data (PRD default was 0.5).
NACTA_FUZZY_THRESHOLD=0.8
UNSC_FUZZY_THRESHOLD=0.65

# ── Automated list sync (cron) ───────────────────────────────────────────────
# Override the defaults below only if the upstream URLs change.
# NACTA_URL=https://nfs.nacta.gov.pk/
# UNSC_URL=https://scsanctions.un.org/resources/xml/en/consolidated.xml
# NACTA_SYNC_TIMEOUT_MS=180000
# LIST_SYNC_USER_ID=1      # which users.id owns auto-sync uploads
# UNSC_FORCE_DOWNLOAD=1    # set to 1 to bypass the UNSC feed-hash skip (rare)
