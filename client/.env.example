# Frontend env (Vite exposes only VITE_*-prefixed vars to the client).
# Copy to .env. In dev the API is reached via the Vite proxy at /api, so this
# default is usually fine. In production point it at the public API origin.
VITE_API_URL=/api

# Backend origin the Vite dev proxy forwards /api to (build/dev only):
VITE_PROXY_TARGET=http://localhost:4000
